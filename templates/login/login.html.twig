{% extends 'base.html.twig' %}

{% block title %}Connexion
{% endblock %}

{% block body %}
	<section class="hero-inner-inscription">

		<div class="container d-flex flex-column align-items-center mt-5">

			<div class="card formulaire-inscription align-items-center">
				
				<form method="post" action="{{path('app_login')}}">
					{% if error %}
						<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
					{% endif %}

					{% if app.user %}
						<div class="mb-3">
							You are logged in as
							{{ app.user.userIdentifier }},
							<a href="{{ logout_path() }}">Logout</a>
						</div>
					{% endif %}

					<h1 class="h3 mb-3 font-weight-bold titre">Connectez vous</h1>
					<label for="username">Email</label>
					<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control mb-2" autocomplete="email" required autofocus>
					<label for="password">Mot de passe</label>
					<input type="password" name="_password" id="password" class="form-control mb-3" autocomplete="current-password" required>
					<input
					type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">
                    <input type="hidden" name="_target_path" value="{{ path('app_home') }}">

					{#
					            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
					            See https://symfony.com/doc/current/security/remember_me.html
					
					            <div class="checkbox mb-3">
					                <input type="checkbox" name="_remember_me" id="_remember_me">
					                <label for="_remember_me">Remember me</label>
					            </div>
					        #}

					<button class="btn mb-3 connexion-bouton" type="submit">
						Se connecter
					</button>
				</form>

				<p>Vous n' avez pas de compte?
					<a href="{{ path('app_inscription') }}">Inscrivez Vous</a>
				</p>
			</div>

		</div>
	</section>

{% endblock %}
